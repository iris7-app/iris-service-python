# Template for local environment configuration.
# Copy to .env (gitignored) and fill in your values.
# Never commit secrets — use a secrets manager (Vault, AWS SSM) in production.
#
# .env and .env.example MUST have the same KEYS (values may differ).
# When adding/removing a variable, update both files together.

# ── Server ────────────────────────────────────────────────────────────────────
IRIS_SERVER_HOST=0.0.0.0
IRIS_SERVER_PORT=8080
IRIS_DEV_MODE=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
IRIS_DB__HOST=localhost
IRIS_DB__PORT=5432
IRIS_DB__NAME=iris
IRIS_DB__USER=iris
IRIS_DB__PASSWORD=iris

# ── Redis ─────────────────────────────────────────────────────────────────────
IRIS_REDIS__HOST=localhost
IRIS_REDIS__PORT=6379
IRIS_REDIS__DB=0

# ── Kafka ─────────────────────────────────────────────────────────────────────
IRIS_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
IRIS_KAFKA__CUSTOMER_REQUEST_TOPIC=customer.enrich.request
IRIS_KAFKA__CUSTOMER_REPLY_TOPIC=customer.enrich.reply
IRIS_KAFKA__ENRICH_TIMEOUT_SECONDS=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(64))"
IRIS_JWT__SECRET=change-me-in-prod-use-token_urlsafe-64
IRIS_JWT__ALGORITHM=HS256
IRIS_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
IRIS_JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenTelemetry ────────────────────────────────────────────────────────────
IRIS_OTEL_ENDPOINT=http://localhost:4318
IRIS_OTEL_SERVICE_NAME=iris-service-python
